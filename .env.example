# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/tanker_filling_station

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# App
RECEIPT_PREFIX=WTR

# Super Admin (first-boot credentials — change after first login)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_DEFAULT_PASSWORD=Admin@1234

# CORS — comma-separated list of allowed origins (leave blank to allow all in dev)
# CORS_ORIGIN=https://yourapp.com,https://admin.yourapp.com
